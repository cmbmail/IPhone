<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cmbchina.phonebiz.mapper.WorkOrderMapper">

    <resultMap id="BaseResultMap" type="com.cmbchina.phonebiz.entity.WorkOrder">
        <id column="id" property="id"/>
        <result column="order_no" property="orderNo"/>
        <result column="order_type" property="orderType"/>
        <result column="status" property="status"/>
        <result column="phone_id" property="phoneId"/>
        <result column="phone_number" property="phoneNumber"/>
        <result column="requester_id" property="requesterId"/>
        <result column="requester_name" property="requesterName"/>
        <result column="handler_id" property="handlerId"/>
        <result column="handler_name" property="handlerName"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="reason" property="reason"/>
        <result column="result" property="result"/>
        <result column="priority" property="priority"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="del_flag" property="delFlag"/>
    </resultMap>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM work_order
        WHERE status = #{status}
        AND del_flag = 0
        ORDER BY create_time DESC
    </select>

    <select id="selectByRequesterId" resultMap="BaseResultMap">
        SELECT * FROM work_order
        WHERE requester_id = #{requesterId}
        AND del_flag = 0
        ORDER BY create_time DESC
    </select>

    <select id="selectByHandlerId" resultMap="BaseResultMap">
        SELECT * FROM work_order
        WHERE handler_id = #{handlerId}
        AND del_flag = 0
        ORDER BY create_time DESC
    </select>

    <select id="selectByPhoneId" resultMap="BaseResultMap">
        SELECT * FROM work_order
        WHERE phone_id = #{phoneId}
        AND del_flag = 0
        ORDER BY create_time DESC
    </select>

</mapper>
